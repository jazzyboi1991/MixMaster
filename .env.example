# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# OCI Object Storage
OCI_NAMESPACE=cn5brhz58dgr
OCI_BUCKET_NAME=mixmaster-datalake
OCI_REGION=ap-seoul-1
OCI_CONFIG_FILE=~/.oci/config

# MySQL (로컬 VM 설치형)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mixmaster
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=mixmaster

# Chroma DB 경로 (Block Volume 마운트 경로)
DB_DIR=/mnt/mixmaster-data/chroma_db
